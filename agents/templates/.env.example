# Authentication Configuration Template
# Copy this file to .env and fill in your credentials
# NEVER commit .env files to version control

# ===========================================
# GitHub Authentication
# ===========================================
# Required for: GitHub Repo Manager, MCP GitHub Server
# Create token at: https://github.com/settings/tokens
# Scopes needed: repo, workflow, read:org, write:packages
GITHUB_TOKEN=ghp_your_github_personal_access_token

# ===========================================
# Google Cloud / Firebase Authentication
# ===========================================
# Required for: Cross-Platform Integration Agent
# Create service account at: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: Firebase CLI token
FIREBASE_TOKEN=your-firebase-cli-token

# ===========================================
# Azure Authentication
# ===========================================
# Required for: Cross-Platform Integration Agent
# Create service principal: az ad sp create-for-rbac --sdk-auth
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_SERVICE_PRINCIPAL_ID=your-client-id
AZURE_SERVICE_PRINCIPAL_SECRET=your-client-secret
AZURE_TENANT_ID=your-tenant-id

# ===========================================
# Expo / EAS Authentication
# ===========================================
# Required for: Mobile deployment
# Get token at: https://expo.dev/settings/access-tokens
EXPO_TOKEN=your-expo-access-token

# For iOS App Store deployment
APPLE_ID=your-apple-id@email.com
APPLE_APP_SPECIFIC_PASSWORD=your-app-specific-password

# For Google Play Store deployment
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=/path/to/play-service-account.json

# ===========================================
# Manus Pro Authentication
# ===========================================
# Required for: Manus Pro automation
MANUS_API_KEY=your-manus-api-key
MANUS_WORKSPACE_ID=your-workspace-id

# ===========================================
# Emergent AI Authentication
# ===========================================
# Required for: Emergent AI connectors
EMERGENT_API_KEY=your-emergent-api-key
EMERGENT_WORKSPACE_ID=your-workspace-id

# ===========================================
# MCP Server Keys
# ===========================================
# Brave Search API (for web search capability)
BRAVE_API_KEY=your-brave-search-api-key

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_TEAM_ID=your-slack-team-id

# Database Connections
DATABASE_URL=postgresql://user:password@host:5432/database
SQLITE_DB_PATH=./data/local.db

# ===========================================
# Additional Service Keys
# ===========================================
# Snyk for security scanning
SNYK_TOKEN=your-snyk-token

# Codecov for coverage reporting
CODECOV_TOKEN=your-codecov-token

# Sentry for error tracking
SENTRY_AUTH_TOKEN=your-sentry-token
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# Docker Hub
DOCKER_USERNAME=your-docker-username
DOCKER_TOKEN=your-docker-token

# Vercel
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id

# Netlify
NETLIFY_AUTH_TOKEN=your-netlify-token
NETLIFY_SITE_ID=your-site-id

# OpenAI (for AI features)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (for Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key