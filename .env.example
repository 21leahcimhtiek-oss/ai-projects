# Stripe Price IDs
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# ── AI (Google Gemini) ────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Expo / Mobile ─────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000
