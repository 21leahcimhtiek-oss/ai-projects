DATABASE_URL=sqlite:./dev.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@host:5432/storyforge

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
