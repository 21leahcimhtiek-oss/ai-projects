{
  "name": "@storyforge/ui",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./button": {
      "import": "./src/components/Button.tsx",
      "types": "./src/components/Button.tsx"
    },
    "./input": {
      "import": "./src/components/Input.tsx",
      "types": "./src/components/Input.tsx"
    },
    "./card": {
      "import": "./src/components/Card.tsx",
      "types": "./src/components/Card.tsx"
    },
    "./badge": {
      "import": "./src/components/Badge.tsx",
      "types": "./src/components/Badge.tsx"
    },
    "./spinner": {
      "import": "./src/components/Spinner.tsx",
      "types": "./src/components/Spinner.tsx"
    },
    "./hooks/*": {
      "import": "./src/hooks/*.ts",
      "types": "./src/hooks/*.ts"
    }
  },
  "files": ["src"],
  "dependencies": {
    "@storyforge/utils": "workspace:*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@storyforge/tsconfig": "workspace:*",
    "@types/react": "~18.3.21",
    "@types/react-dom": "~18.3.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}