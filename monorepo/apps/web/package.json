{
  "name": "@storyforge/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":       "vite",
    "build":     "tsc --noEmit && vite build",
    "preview":   "vite preview",
    "lint":      "eslint src --ext .ts,.tsx --max-warnings 0",
    "lint:fix":  "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean":     "rm -rf dist .turbo"
  },
  "dependencies": {
    "@storyforge/api-client": "workspace:*",
    "@storyforge/types":      "workspace:*",
    "@storyforge/ui":         "workspace:*",
    "@storyforge/utils":      "workspace:*",
    "@stripe/stripe-js":      "^8.6.3",
    "@tanstack/react-query":  "^5.90.12",
    "@trpc/client":           "11.8.0",
    "@trpc/react-query":      "11.8.0",
    "clsx":                   "^2.1.1",
    "lucide-react":           "^0.511.0",
    "react":                  "18.3.1",
    "react-dom":              "18.3.1",
    "react-router-dom":       "^6.30.0",
    "tailwind-merge":         "^3.3.0",
    "zod":                    "^3.25.51"
  },
  "devDependencies": {
    "@storyforge/eslint-config":   "workspace:*",
    "@storyforge/prettier-config": "workspace:*",
    "@storyforge/tsconfig":        "workspace:*",
    "@types/react":                "~18.3.21",
    "@types/react-dom":            "~18.3.7",
    "@vitejs/plugin-react":        "^4.5.2",
    "autoprefixer":                "^10.4.21",
    "postcss":                     "^8.5.3",
    "tailwindcss":                 "^3.4.17",
    "typescript":                  "^5.8.3",
    "vite":                        "^6.3.5"
  },
  "prettier": "@storyforge/prettier-config"
}