{
  "name": "@storyforge/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev":       "expo start",
    "android":   "expo start --android",
    "ios":       "expo start --ios",
    "build:android": "eas build --platform android --profile preview",
    "build:ios":     "eas build --platform ios --profile preview",
    "lint":      "eslint app src --ext .ts,.tsx --max-warnings 0",
    "lint:fix":  "eslint app src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean":     "rm -rf .expo .turbo"
  },
  "dependencies": {
    "@storyforge/api":                       "workspace:*",
    "@storyforge/api-client":                "workspace:*",
    "@storyforge/types":                     "workspace:*",
    "@storyforge/utils":                     "workspace:*",
    "@expo/vector-icons":                    "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs":         "^7.8.12",
    "@react-navigation/native":              "^7.1.25",
    "@tanstack/react-query":                 "^5.90.12",
    "@trpc/client":                          "11.8.0",
    "@trpc/react-query":                     "11.8.0",
    "expo":                                  "~54.0.29",
    "expo-audio":                            "~1.1.0",
    "expo-constants":                        "~18.0.12",
    "expo-font":                             "~14.0.10",
    "expo-haptics":                          "~15.0.8",
    "expo-linking":                          "~8.0.10",
    "expo-notifications":                    "~0.32.15",
    "expo-router":                           "~4.0.20",
    "expo-splash-screen":                    "~0.29.22",
    "expo-status-bar":                       "~2.0.1",
    "expo-system-ui":                        "~4.0.9",
    "expo-web-browser":                      "~14.0.2",
    "lucide-react-native":                   "^0.511.0",
    "react":                                 "18.3.1",
    "react-native":                          "0.76.9",
    "react-native-gesture-handler":          "~2.20.2",
    "react-native-reanimated":               "~3.16.7",
    "react-native-safe-area-context":        "4.12.0",
    "react-native-screens":                  "~4.4.0",
    "react-native-web":                      "~0.19.13",
    "zod":                                   "^3.25.51"
  },
  "devDependencies": {
    "@storyforge/eslint-config":   "workspace:*",
    "@storyforge/prettier-config": "workspace:*",
    "@storyforge/tsconfig":        "workspace:*",
    "@types/react":                "~18.3.21",
    "@types/react-native":         "^0.73.0",
    "typescript":                  "^5.8.3"
  },
  "prettier": "@storyforge/prettier-config"
}