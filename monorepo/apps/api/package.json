{
  "name": "@storyforge/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":       "tsx watch src/index.ts",
    "build":     "esbuild src/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist --sourcemap",
    "start":     "node dist/index.js",
    "lint":      "eslint src --ext .ts --max-warnings 0",
    "lint:fix":  "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean":     "rm -rf dist .turbo",
    "db:push":   "drizzle-kit generate && drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed":   "tsx src/database/seed.ts"
  },
  "dependencies": {
    "@storyforge/types":          "workspace:*",
    "@storyforge/utils":          "workspace:*",
    "@google/generative-ai":      "^0.24.1",
    "@supabase/supabase-js":      "^2.49.0",
    "@trpc/server":               "11.8.0",
    "bcryptjs":                   "^2.4.3",
    "cookie":                     "^1.1.1",
    "cors":                       "^2.8.5",
    "dotenv":                     "^16.6.1",
    "drizzle-orm":                "^0.44.7",
    "express":                    "^4.21.2",
    "jose":                       "^5.10.0",
    "pdfkit":                     "^0.17.0",
    "postgres":                   "^3.4.5",
    "stripe":                     "^17.7.0",
    "zod":                        "^3.25.51"
  },
  "devDependencies": {
    "@storyforge/eslint-config":   "workspace:*",
    "@storyforge/prettier-config": "workspace:*",
    "@storyforge/tsconfig":        "workspace:*",
    "@types/bcryptjs":             "^2.4.6",
    "@types/cookie":               "^1.0.0",
    "@types/cors":                 "^2.8.17",
    "@types/express":              "^5.0.3",
    "@types/node":                 "^22.15.21",
    "drizzle-kit":                 "^0.31.1",
    "esbuild":                     "^0.25.4",
    "tsx":                         "^4.19.4",
    "typescript":                  "^5.8.3"
  },
  "prettier": "@storyforge/prettier-config"
}