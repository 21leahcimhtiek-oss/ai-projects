# ─── StoryForge Kids — Environment Variables ──────────────────────────────────
# Copy this file to .env in apps/api/ and fill in real values.
# NEVER commit .env files to git.

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (Supabase / PostgreSQL) ────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
# Get from: https://dashboard.stripe.com/products
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...

# ─── AI (Google Gemini) ───────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081

# ─── Web App (Vite) ───────────────────────────────────────────────────────────
# Leave empty in dev — Vite proxies /api to localhost:3000
VITE_API_URL=
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Mobile App (Expo) ───────────────────────────────────────────────────────
# Must be prefixed with EXPO_PUBLIC_ to be accessible in the app bundle
EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── Vercel (auto-injected — do not set manually) ────────────────────────────
# VERCEL_URL=
# VERCEL_ENV=
# VERCEL_GIT_COMMIT_SHA=